name: Build Redmi 4X (santoni) Boot.img

on:
  push:
    branches: [ main ]
    paths:
      - '.github/workflows/build-santoni-bootimg.yml'
  pull_request:
    branches: [ main ]
  workflow_dispatch: # 支持手动触发

jobs:
  build-bootimg:
    runs-on: ubuntu-22.04
    steps:
      - name: Install Dependencies
        run: |
          sudo apt update && sudo apt upgrade -y
          sudo apt install -y \
            git build-essential gcc-aarch64-linux-gnu \
            bc bison flex libssl-dev python3-pip \
            mkbootimg cpio kmod

      - name: Clone Mainline Kernel (LTS)
        run: |
          # 选择 6.1 LTS 内核（兼容性最佳）
          git clone --depth 1 --branch v6.1.90 \
            https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git linux-santoni
          cd linux-santoni

      - name: Configure Kernel for Redmi 4X
        run: |
          cd linux-santoni
          # 基础 arm64 配置
          make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- defconfig
          # 启用 MSM8940/Redmi 4X 硬件支持
          cat >> .config << EOF
          CONFIG_MSM8940=y
          CONFIG_ARCH_QCOM=y
          CONFIG_QCOM_SOC_COMMON=y
          CONFIG_QCOM_GPIOMUX=y
          CONFIG_QCOM_SPMI=y
          CONFIG_QCOM_PMIC=y
          CONFIG_QCOM_RPM=y
          CONFIG_QCOM_SMD=y
          CONFIG_QCOM_WCNSS_CTRL=y
          CONFIG_WLAN=y
          CONFIG_WLAN_VENDOR_QCOM=y
          CONFIG_QCA_WIFI_PHY=y
          CONFIG_QCOM_SSBI=y
          CONFIG_QCOM_SMEM=y
          CONFIG_MMC=y
          CONFIG_MMC_SDHCI=y
          CONFIG_MMC_SDHCI_QCOM=y
          CONFIG_SERIAL_QCOM_MSM=y
          CONFIG_FB_SIMPLE=y
          CONFIG_DRM=y
          CONFIG_DRM_MSM=y
          CONFIG_DRM_MSM_GPU=y
          EOF
          # 生成最终配置
          make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- olddefconfig

      - name: Compile Kernel & DTB
        run: |
          cd linux-santoni
          # 编译内核、模块、设备树
          make -j$(nproc) ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- \
            Image.gz dtbs modules
          # 安装模块到临时目录
          mkdir -p ../kernel-modules/lib
          make ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- \
            INSTALL_MOD_PATH=../kernel-modules modules_install

      - name: Build Initramfs (带驱动模块)
        run: |
          # 拷贝内核模块到 initramfs 构建目录
          mkdir -p initramfs/{lib/modules,bin,sbin,etc}
          cp -r kernel-modules/lib/modules/* initramfs/lib/modules/
          # 生成 initramfs 配置
          cat > initramfs/init << 'EOF'
          #!/bin/sh
          mount -t proc proc /proc
          mount -t sysfs sysfs /sys
          mount -t devtmpfs devtmpfs /dev
          depmod -a $(uname -r)
          exec switch_root /sysroot /sbin/init
          EOF
          chmod +x initramfs/init
          # 打包 initramfs
          cd initramfs
          find . -print0 | cpio --null -ov --format=newc | gzip -9 > ../initramfs.gz
          cd ..

      - name: Generate boot.img (适配 Redmi 4X)
        run: |
          # 关键参数：Redmi 4X 分区表 + 内存布局
          mkbootimg \
            --kernel linux-santoni/arch/arm64/boot/Image.gz \
            --ramdisk initramfs.gz \
            --dtb linux-santoni/arch/arm64/boot/dts/qcom/msm8940-santoni.dtb \
            --base 0x80000000 \
            --pagesize 2048 \
            --cmdline "console=ttyMSM0,115200n8 root=/dev/mmcblk0p22 rootwait rw no_console_suspend" \
            --output santoni-debian-boot.img

      - name: Verify boot.img
        run: |
          # 检查 boot.img 结构
          file santoni-debian-boot.img
          # 输出信息
          echo "Boot.img 构建完成：santoni-debian-boot.img"

      - name: Upload Artifact
        uses: actions/upload-artifact@v4
        with:
          name: santoni-boot-img
          path: santoni-debian-boot.img
          retention-days: 30
